{
  "name": "choux",
  "version": "0.3.0",
  "description": "Make network requests against a JSON API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup --clean",
    "build:ci": "tsup",
    "lint:ci": "npx eslint .",
    "lint": "npx eslint . --fix",
    "test:ci": "jest --ci",
    "test:watch": "jest --watch",
    "test": "jest",
    "tsc:watch": "npx tsc --watch",
    "tsc": "npx tsc",
    "verify": "npm run tsc && npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericmeyer/choux.git"
  },
  "author": "Eric Meyer",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ericmeyer/choux/issues"
  },
  "homepage": "https://github.com/ericmeyer/choux#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
